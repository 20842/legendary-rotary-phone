class Solution:
    def firstMissingPositive(self, nums: List[int]) -> int:
        n = len(nums)
        
        # Phase 1: Cyclic Sort (Place each x at index x-1)
        for i in range(n):
            # Only swap if the number is in range [1, n] 
            # and not already at its correct destination
            while 1 <= nums[i] <= n and nums[nums[i] - 1] != nums[i]:
                # Swap nums[i] with the element at its target index
                target_idx = nums[i] - 1
                nums[i], nums[target_idx] = nums[target_idx], nums[i]
        
        # Phase 2: Find the first index where the value is incorrect
        for i in range(n):
            if nums[i] != i + 1:
                return i + 1
        
        # If all numbers 1 to n are present, the answer is n + 1
        return n + 1
