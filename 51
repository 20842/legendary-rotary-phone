class Solution:
    def solveNQueens(self, n: int) -> List[List[str]]:
        res = []
        board = [["."] * n for _ in range(n)]
        
        # Track occupied columns and both types of diagonals
        cols = set()
        pos_diag = set() # (r + c) remains constant along anti-diagonals
        neg_diag = set() # (r - c) remains constant along main diagonals
        
        def backtrack(r):
            # Base case: All queens placed
            if r == n:
                res.append(["".join(row) for row in board])
                return
            
            for c in range(n):
                # If the current spot is threatened, skip it
                if c in cols or (r + c) in pos_diag or (r - c) in neg_diag:
                    continue
                
                # 1. Place queen
                cols.add(c)
                pos_diag.add(r + c)
                neg_diag.add(r - c)
                board[r][c] = "Q"
                
                # 2. Recurse to the next row
                backtrack(r + 1)
                
                # 3. Backtrack (remove queen)
                cols.remove(c)
                pos_diag.remove(r + c)
                neg_diag.remove(r - c)
                board[r][c] = "."
                
        backtrack(0)
        return res
